{
  "openapi": "3.0.0",
  "info": {
    "title": "Food Delivery API",
    "version": "1.0.0",
    "description": "API documentation for a food delivery system"
  },
  "servers": [
    {
      "url": "http://localhost:4000",
      "description": "Local server"
    }
  ],
  "tags": [
    {
      "name": "Users",
      "description": "Operations related to users"
    },
    {
      "name": "Cart",
      "description": "Operations related to cart"
    },
    {
      "name": "Restaurants & Menu",
      "description": "Operations related to Restaurants and their related menu"
    }
  ],
  "paths": {
    "/api/v1/user/signup": {
      "post": {
        "tags": ["Users"],
        "summary": "create new user account",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/user"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User Created Successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    },
    "/api/v1/user/signin": {
      "post": {
        "tags": ["Users"],
        "summary": "existing user sign in",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "example": "john@mail.com"
                  },
                  "password": {
                    "type": "string",
                    "example": "password"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User Login Successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "401": {
            "description": "unauthorized user"
          }
        }
      }
    },
    "/api/v1/user/signout": {
      "post": {
        "tags": ["Users"],
        "summary": "existing user sign out",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "customerId": { "type": "string", "example": "1" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User sign out Successfully"
          },
          "401": {
            "description": "unauthorized user"
          }
        }
      }
    },
    "/api/v1/user/forget-password": {
      "post": {
        "tags": ["Users"],
        "summary": "forget password ",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "example": "user@email.com" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "send email with reset link"
          },
          "401": {
            "description": "unauthorized user"
          }
        }
      }
    },
    "/api/v1/user/reset-password": {
      "put": {
        "tags": ["Users"],
        "summary": "reset password",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "example": "abc123"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "password": { "type": "string", "example": "newPass" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password reset successfully"
          },
          "400": {
            "description": "Token expired "
          }
        }
      }
    },
    "/api/v1/user/toggle-account": {
      "put": {
        "tags": ["Users"],
        "summary": "disable or enable account",
        "description": "it allows user to either enable or disable his account according to the coming  'Enable' value if is true or false",
        "security": [
          {
            "BearerAuth": [],
            "CookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "customerId": { "type": "string", "example": "5" },
                  "enable": { "type": "boolean", "example": true }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The account is enabled/disabled successfully"
          },
          "401": {
            "description": "unauthorized user"
          }
        }
      }
    },
    "/api/v1/user/profile/{userId}": {
      "get": {
        "tags": ["Users"],
        "summary": "display user profile",
        "security": [
          {
            "BearerAuth": [],
            "CookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "description": "User ID",
            "schema": {
              "type": "string",
              "example": "10"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Display user profile successfully"
          },
          "401": {
            "description": "unauthorized user"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      },
      "put": {
        "tags": ["Users"],
        "summary": "Edit user profile",
        "security": [
          {
            "BearerAuth": [],
            "CookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "description": "User ID",
            "schema": {
              "type": "string",
              "example": "10"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "customerId": { "type": "string", "example": "5" },
                  "userData": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Edit user profile successfully"
          },
          "401": {
            "description": "unauthorized user"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    },
    "/api/v1/cart/add": {
      "post": {
        "tags": ["Cart"],
        "summary": "create cart and add items to it",
        "security": [
          {
            "BearerAuth": [],
            "CookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "customerId": {
                    "type": "string",
                    "example": "48"
                  },
                  "itemId": {
                    "type": "string",
                    "example": "item_58"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Item added to cart successfully"
          },
          "404": {
            "description": "Customer Not Found Or Item Not found"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    },
    "/api/v1/cart/modify/{cartId}": {
      "delete": {
        "tags": ["Cart"],
        "summary": "remove item from cart",
        "security": [
          {
            "BearerAuth": [],
            "CookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "cartId",
            "in": "path",
            "required": true,
            "description": "Cart ID",
            "schema": {
              "type": "string",
              "example": "cart_10"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "itemId": {
                    "type": "string",
                    "example": "item_58"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Item removed successfully"
          },
          "404": {
            "description": "Cart Not Found Or Item Not found"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      },
      "put": {
        "tags": ["Cart"],
        "summary": "increment /decrement item quantity in cart",
        "security": [
          {
            "BearerAuth": [],
            "CookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "cartId",
            "in": "path",
            "required": true,
            "description": "Cart ID",
            "schema": {
              "type": "string",
              "example": "cart_10"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "itemId": {
                    "type": "string",
                    "example": "item_58"
                  },
                  "event_type": {
                    "type": "string",
                    "enum": ["increment", "decrement"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Item updated successfully"
          },
          "404": {
            "description": "Cart Not Found Or Item Not found"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    },
    "/api/v1/cart/{cartId}": {
      "get": {
        "tags": ["Cart"],
        "summary": "view entire cart",
        "security": [
          {
            "BearerAuth": [],
            "CookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "cartId",
            "in": "path",
            "required": true,
            "description": "Cart ID",
            "schema": {
              "type": "string",
              "example": "cart_10"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "cart items displayed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/cartItems"
                }
              }
            }
          },
          "404": {
            "description": "Cart Not Found Or Item Not found"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      },
      "delete": {
        "tags": ["Cart"],
        "summary": "delete entire cart",
        "security": [
          {
            "BearerAuth": [],
            "CookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "cartId",
            "in": "path",
            "required": true,
            "description": "Cart ID",
            "schema": {
              "type": "string",
              "example": "cart_10"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "entire cart removed successfully"
          },
          "404": {
            "description": "Cart Not Found"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    },
    "/api/v1/restaurant/add": {
      "post": {
        "tags": ["Restaurants & Menu"],
        "summary": "Add Restaurant to app",
        "security": [
          {
            "BearerAuth": [],
            "CookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "ownerId": {
                    "type": "string",
                    "example": "5"
                  },
                  "restaurantDetails": {
                    "$ref": "#/components/schemas/restaurant"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "restaurant added successfully"
          },
          "404": {
            "description": "Customer Not Found"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    },
    "/api/v1/restaurant/{restaurantId}": {
      "get": {
        "tags": ["Restaurants & Menu"],
        "summary": "get Restaurant data",
        "parameters": [
          {
            "name": "restaurantId",
            "in": "path",
            "required": true,
            "description": "restaurant ID",
            "schema": {
              "type": "string",
              "example": "restaurant_2"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "restaurant data displayed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/menu"
                }
              }
            }
          },
          "404": {
            "description": "restaurant Not Found"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      },
      "put": {
        "tags": ["Restaurants & Menu"],
        "summary": "update  Restaurant data",
        "security": [
          {
            "BearerAuth": [],
            "CookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "restaurantId",
            "in": "path",
            "required": true,
            "description": "restaurant ID",
            "schema": {
              "type": "string",
              "example": "restaurant_2"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "updatedDetails": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "restaurant updated successfully"
          },
          "404": {
            "description": "restaurant Not Found or Owner Not Found"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      },
      "delete": {
        "tags": ["Restaurants & Menu"],
        "summary": "delete entire Restaurant",
        "security": [
          {
            "BearerAuth": [],
            "CookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "restaurantId",
            "in": "path",
            "required": true,
            "description": "restaurant ID",
            "schema": {
              "type": "string",
              "example": "restaurant_2"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "restaurant deleted successfully"
          },
          "404": {
            "description": "restaurant Not Found"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "user": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "example": "John"
          },
          "email": {
            "type": "string",
            "example": "john@mail.com"
          },
          "password": {
            "type": "string",
            "example": "password"
          }
        }
      },
      "cartItems": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "example": "Burger"
            },
            "description": {
              "type": "string",
              "example": "Beef burger with spicy sauce"
            },
            "image": {
              "type": "string",
              "example": "url"
            },
            "price": {
              "type": "integer",
              "example": 25
            },
            "quantity": {
              "type": "integer",
              "example": 2
            }
          }
        }
      },
      "restaurant": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Pizza House"
          },
          "phone": {
            "type": "string",
            "example": "+011111111"
          },
          "location": {
            "type": "string",
            "example": "UK,Liverpool,Roger Street"
          },
          "category": {
            "type": "string",
            "example": "Bakery"
          }
        }
      },
      "menu": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "menu_category": {
              "type": "string",
              "example": "Grilled"
            },
            "menu_items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "item_name": {
                    "type": "string",
                    "example": "Grilled Chicken"
                  },
                  "description": {
                    "type": "string",
                    "example": "Grilled Chicken with Salad and rice"
                  },
                  "image": {
                    "type": "string",
                    "example": "url"
                  },
                  "price": {
                    "type": "integer",
                    "example": 65
                  }
                }
              }
            }
          }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "accessToken": { "type": "string" }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "description": "For accessToken, must add  headers to http request body with authorization: token ",
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "CookieAuth": {
        "description": "For RefreshToken, must add { withCredentials: true } to http request",
        "type": "apiKey",
        "in": "cookie",
        "name": "token"
      }
    }
  }
}
