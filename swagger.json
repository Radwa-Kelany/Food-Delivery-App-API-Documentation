  "components": {
    "schemas": {
      "user": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "example": "John"
          },
          "email": {
            "type": "string",
            "example": "john@mail.com"
          },
          "password": {
            "type": "string",
            "example": "password"
          }
        }
      },
      "cartItems": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "example": "Burger"
            },
            "description": {
              "type": "string",
              "example": "Beef burger with spicy sauce"
            },
            "image": {
              "type": "string",
              "example": "url"
            },
            "price": {
              "type": "integer",
              "example": 25
            },
            "quantity": {
              "type": "integer",
              "example": 2
            }
          }
        }
      },
      "restaurant": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Pizza House"
          },
          "image": {
            "type": "string",
            "example": "url"
          },
          "description": {
            "type": "string",
            "example": "Italian Restaurant for all kinds od pasta and pizza"
          },

          "phone": {
            "type": "string",
            "example": "+011111111"
          },
          "location": {
            "type": "string",
            "example": "UK,Liverpool,Roger Street"
          },
          "category": {
            "type": "string",
            "example": "Bakery"
          }
        }
      },
      "menu": {
        "type": "object",
        "properties": {
          "menu_category": {
            "type": "string",
            "example": "Grilled"
          },
          "menu_items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "item_name": {
                  "type": "string",
                  "example": "Grilled Chicken"
                },
                "description": {
                  "type": "string",
                  "example": "Grilled Chicken with Salad and rice"
                },
                "image": {
                  "type": "string",
                  "example": "url"
                },
                "price": {
                  "type": "integer",
                  "example": 65
                }
              }
            }
          }
        }
      },
      "order_item_details": {
        "type": "object",
        "properties": {
          "item_name": {
            "type": "string",
            "example": "Grilled Chicken"
          },
          "image": {
            "type": "string",
            "example": "url"
          },
          "price": {
            "type": "integer",
            "example": 65
          },
          "quantity": {
            "type": "integer",
            "example": 1
          }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "accessToken": { "type": "string" }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "description": "For accessToken, must add  headers to http request body with authorization: token ",
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "CookieAuth": {
        "description": "For RefreshToken, must add { withCredentials: true } to http request",
        "type": "apiKey",
        "in": "cookie",
        "name": "token"
      }
    }
  }
