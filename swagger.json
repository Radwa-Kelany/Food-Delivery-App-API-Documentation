{
  "openapi": "3.0.0",
  "info": {
    "title": "Food Delivery API",
    "version": "1.0.0",
    "description": "API documentation for a food delivery system"
  },
  "servers": [
    {
      "url": "http://localhost:4000",
      "description": "Local server"
    }
  ],
  "tags": [
    {
      "name": "Users",
      "description": "Operations related to users"
    },
    {
      "name": "Cart",
      "description": "Operations related to cart"
    },
    {
      "name": "Restaurants & Menu",
      "description": "Operations related to Restaurants and their related menu"
    },
    {
      "name": "Orders",
      "description": "Operations related to orders"
    },
    {
      "name": "Payments",
      "description": "Operations related to payments"
    }
  ],
  "paths": {
    "/api/v1/user/signup": {
      "post": {
        "tags": ["Users"],
        "summary": "create new user account",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/user"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User Created Successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    },
    "/api/v1/user/signin": {
      "post": {
        "tags": ["Users"],
        "summary": "existing user sign in",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "example": "john@mail.com"
                  },
                  "password": {
                    "type": "string",
                    "example": "password"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User Login Successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "401": {
            "description": "unauthorized user"
          }
        }
      }
    },
    "/api/v1/user/signout": {
      "post": {
        "tags": ["Users"],
        "summary": "existing user sign out",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "customerId": { "type": "string", "example": "1" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User sign out Successfully"
          },
          "401": {
            "description": "unauthorized user"
          }
        }
      }
    },
    "/api/v1/user/forget-password": {
      "post": {
        "tags": ["Users"],
        "summary": "forget password ",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "example": "user@email.com" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "send email with reset link"
          },
          "401": {
            "description": "unauthorized user"
          }
        }
      }
    },
    "/api/v1/user/reset-password": {
      "put": {
        "tags": ["Users"],
        "summary": "reset password",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "example": "abc123"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "password": { "type": "string", "example": "newPass" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password reset successfully"
          },
          "400": {
            "description": "Token expired "
          }
        }
      }
    },
    "/api/v1/user/toggle-account": {
      "put": {
        "tags": ["Users"],
        "summary": "disable or enable account",
        "description": "it allows user to either enable or disable his account according to the coming  'Enable' value if is true or false",
        "security": [
          {
            "BearerAuth": [],
            "CookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "customerId": { "type": "string", "example": "5" },
                  "enable": { "type": "boolean", "example": true }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The account is enabled/disabled successfully"
          },
          "401": {
            "description": "unauthorized user"
          }
        }
      }
    },
    "/api/v1/user/profile/{userId}": {
      "get": {
        "tags": ["Users"],
        "summary": "display user profile",
        "security": [
          {
            "BearerAuth": [],
            "CookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "description": "User ID",
            "schema": {
              "type": "string",
              "example": "10"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Display user profile successfully"
          },
          "401": {
            "description": "unauthorized user"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      },
      "put": {
        "tags": ["Users"],
        "summary": "Edit user profile",
        "security": [
          {
            "BearerAuth": [],
            "CookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "description": "User ID",
            "schema": {
              "type": "string",
              "example": "10"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "customerId": { "type": "string", "example": "5" },
                  "userData": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Edit user profile successfully"
          },
          "401": {
            "description": "unauthorized user"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    },
    "/api/v1/cart/add": {
      "post": {
        "tags": ["Cart"],
        "summary": "create cart and add items to it",
        "security": [
          {
            "BearerAuth": [],
            "CookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "customerId": {
                    "type": "string",
                    "example": "48"
                  },
                  "itemId": {
                    "type": "string",
                    "example": "item_58"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Item added to cart successfully"
          },
          "404": {
            "description": "Customer Not Found Or Item Not found"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    },
    "/api/v1/cart/modify/{cartId}": {
      "delete": {
        "tags": ["Cart"],
        "summary": "remove item from cart",
        "security": [
          {
            "BearerAuth": [],
            "CookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "cartId",
            "in": "path",
            "required": true,
            "description": "Cart ID",
            "schema": {
              "type": "string",
              "example": "cart_10"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "itemId": {
                    "type": "string",
                    "example": "item_58"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Item removed successfully"
          },
          "404": {
            "description": "Cart Not Found Or Item Not found"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      },
      "put": {
        "tags": ["Cart"],
        "summary": "increment /decrement item quantity in cart",
        "security": [
          {
            "BearerAuth": [],
            "CookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "cartId",
            "in": "path",
            "required": true,
            "description": "Cart ID",
            "schema": {
              "type": "string",
              "example": "cart_10"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "itemId": {
                    "type": "string",
                    "example": "item_58"
                  },
                  "event_type": {
                    "type": "string",
                    "enum": ["increment", "decrement"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Item updated successfully"
          },
          "404": {
            "description": "Cart Not Found Or Item Not found"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    },
